import { ScrollView } from "std-widgets.slint";

export struct ShellRow {
    label: string,
    detail: string,
    selected: bool,
}

export struct QuestSummary {
    title: string,
    status: string,
    group: string,
    badge: string,
    detail: string,
    selected: bool,
}

export struct QuestMetric {
    label: string,
    value: string,
}

component ToolButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> active: false;
    callback clicked();

    height: 26px;
    min-width: 28px;
    border-radius: 5px;
    border-width: 1px;
    border-color: active ? #3F3F46 : #00000000;
    background: active ? #202124 : #00000000;

    Text {
        text: root.text;
        color: root.enabled ? (root.active ? #F4F4F5 : #85858B) : #5F6066;
        font-size: 11px;
        font-weight: root.active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component QuestListRow inherits Rectangle {
    in property <QuestSummary> quest;
    callback clicked();

    height: 32px;
    border-radius: 7px;
    border-width: 0px;
    background: quest.selected ? #E7E7E5 : #00000000;

    HorizontalLayout {
        padding-left: 9px;
        padding-right: 8px;
        spacing: 8px;

        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: quest.status == "completed" ? #22C55E : (quest.status == "blocked" || quest.status == "canceled" ? #EF4444 : (quest.status == "running" || quest.status == "validating" || quest.status == "repairing" ? #52525B : #94A3B8));
            vertical-stretch: 0;
        }

        VerticalLayout {
            alignment: center;
            spacing: 1px;

            Text {
                text: quest.title;
                color: quest.selected ? #202124 : #3C4043;
                font-size: 12px;
                font-weight: quest.selected ? 600 : 500;
                overflow: elide;
            }

            Text {
                text: quest.detail;
                color: #8A8D91;
                font-size: 10px;
                overflow: elide;
            }
        }
    }

    TouchArea { clicked => { root.clicked(); } }
}

component QuestSidebarButton inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> active: false;
    callback clicked();

    height: 30px;
    border-radius: 7px;
    background: active ? #E7E7E5 : #00000000;

    HorizontalLayout {
        padding-left: 9px;
        padding-right: 8px;
        spacing: 8px;

        Text { text: root.glyph; color: #5F6368; font-size: 13px; vertical-alignment: center; horizontal-alignment: center; width: 16px; }
        Text { text: root.label; color: active ? #202124 : #5F6368; font-size: 12px; font-weight: active ? 600 : 500; vertical-alignment: center; overflow: elide; }
    }

    TouchArea { clicked => { root.clicked(); } }
}

component QuestHeaderButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #E4E4E2;
    background: enabled ? #FFFFFF : #F5F5F4;

    Text {
        text: root.text;
        color: enabled ? #343434 : #A1A1AA;
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component QuestMetricCard inherits Rectangle {
    in property <QuestMetric> metric;

    min-height: 54px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #E5E7EB;
    background: #FAFAFA;

    VerticalLayout {
        padding: 9px;
        spacing: 5px;

        Text {
            text: metric.label;
            color: #8A8D91;
            font-size: 10px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: metric.value;
            color: #202124;
            font-size: 12px;
            font-weight: 700;
            overflow: elide;
        }
    }
}

component PanelHeader inherits Rectangle {
    in property <string> kicker;
    in property <string> title;
    in property <string> meta: "";

    height: 42px;
    background: #121316DB;
    border-width: 1px;
    border-color: #2B2C31;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 8px;

        VerticalLayout {
            alignment: center;
            spacing: 2px;

            Text {
                text: root.title;
                color: #F4F4F5;
                font-size: 12px;
                font-weight: 700;
                overflow: elide;
            }

            Text {
                text: root.kicker;
                color: #85858B;
                font-size: 10px;
                font-weight: 600;
                overflow: elide;
            }
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: root.meta;
            color: #85858B;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

component ListPanel inherits Rectangle {
    in property <string> title;
    in property <string> kicker;
    in property <string> meta: "";
    in property <[ShellRow]> rows;
    callback row-clicked(int);

    background: #151619;
    border-width: 1px;
    border-color: #2B2C31;

    VerticalLayout {
        spacing: 0px;

        PanelHeader {
            title: root.title;
            kicker: root.kicker;
            meta: root.meta;
        }

        ScrollView {
            VerticalLayout {
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 1px;

                for row[index] in root.rows: Rectangle {
                    height: 28px;
                    background: row.selected ? #123421 : #151619;
                    border-width: 0px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 9px;
                        spacing: 8px;

                        Rectangle {
                            width: 5px;
                            height: 5px;
                            border-radius: 3px;
                            background: row.selected ? #4ADE80 : #22C55E;
                            vertical-stretch: 0;
                        }

                        Text {
                            text: row.label;
                            color: row.selected ? #F4F4F5 : #C3C3C7;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: row.detail;
                            color: #85858B;
                            font-size: 10px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    TouchArea {
                        clicked => { root.row-clicked(index); }
                    }
                }
            }
        }
    }
}


component QuestWorkspace inherits Rectangle {
    in property <[QuestSummary]> quests;
    in property <[ShellRow]> quest-timeline;
    in property <[ShellRow]> quest-tasks;
    in property <[ShellRow]> quest-files;
    in property <[ShellRow]> quest-knowledge;
    in property <[QuestMetric]> quest-metrics;
    in property <string> quest-tab: "overview";
    in property <string> quest-title: "Quests";
    in property <string> quest-status: "";
    in property <string> quest-goal: "";
    in property <string> quest-next-action: "";
    in property <string> quest-next-reason: "";
    in property <string> quest-document: "";
    in property <bool> has-selected-quest: false;
    callback quest-selected(int);
    callback quest-tab-selected(string);
    callback quest-action(string);

    property <bool> show-artifact-pane: root.has-selected-quest && root.quest-tab != "overview";

    background: #FFFFFF;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 280px;
            background: #F7F7F6;
            border-width: 1px;
            border-color: #E5E5E3;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 48px;
                    background: #F7F7F6;

                    HorizontalLayout {
                        padding-left: 13px;
                        padding-right: 11px;
                        spacing: 13px;

                        Text { text: "□"; color: #5F6368; font-size: 15px; vertical-alignment: center; }
                        Text { text: "⌕"; color: #5F6368; font-size: 16px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                Rectangle {
                    height: 50px;
                    background: #F7F7F6;

                    Rectangle {
                        x: 12px;
                        y: 6px;
                        width: 256px;
                        height: 38px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #DFDFDD;
                        background: #FFFFFF;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 10px;
                            spacing: 8px;

                            Text { text: "+"; color: #202124; font-size: 17px; vertical-alignment: center; }
                            Text { text: "New Quest"; color: #202124; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                            Rectangle { horizontal-stretch: 1; }
                            Text { text: "Ctrl N"; color: #8A8D91; font-size: 10px; vertical-alignment: center; }
                        }

                        TouchArea { clicked => { root.quest-action("new"); } }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: #F7F7F6;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 12px;
                        spacing: 8px;

                        Text { text: "Quests"; color: #8A8D91; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: "▦"; color: #8A8D91; font-size: 12px; vertical-alignment: center; }
                        Text { text: "⊞"; color: #8A8D91; font-size: 12px; vertical-alignment: center; }
                    }
                }

                QuestSidebarButton {
                    label: "Aster";
                    glyph: "▱";
                    active: true;
                }

                ScrollView {
                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 10px;
                        padding-top: 4px;
                        padding-bottom: 12px;
                        spacing: 1px;

                        Text { text: "Needs action"; color: #8A8D91; font-size: 11px; font-weight: 600; }
                        for quest[index] in root.quests: QuestListRow {
                            visible: quest.group == "needs_action";
                            quest: quest;
                            clicked => { root.quest-selected(index); }
                        }

                        Rectangle { height: 8px; background: #F7F7F6; }
                        Text { text: "Running"; color: #8A8D91; font-size: 11px; font-weight: 600; }
                        for quest[index] in root.quests: QuestListRow {
                            visible: quest.group == "running";
                            quest: quest;
                            clicked => { root.quest-selected(index); }
                        }

                        Rectangle { height: 8px; background: #F7F7F6; }
                        Text { text: "Recent"; color: #8A8D91; font-size: 11px; font-weight: 600; }
                        for quest[index] in root.quests: QuestListRow {
                            visible: quest.group == "recent";
                            quest: quest;
                            clicked => { root.quest-selected(index); }
                        }

                        Rectangle { height: 8px; background: #F7F7F6; }
                        Text { text: "Archived"; color: #8A8D91; font-size: 11px; font-weight: 600; }
                        for quest[index] in root.quests: QuestListRow {
                            visible: quest.group == "archived";
                            quest: quest;
                            clicked => { root.quest-selected(index); }
                        }

                        Rectangle { height: 18px; background: #F7F7F6; }
                        Text { text: "Chats"; color: #8A8D91; font-size: 13px; font-weight: 500; }
                        Rectangle { height: 12px; background: #F7F7F6; }
                        Text { text: "No Quest yet"; color: #9AA0A6; font-size: 12px; }
                    }
                }

                Rectangle {
                    height: 86px;
                    background: #F7F7F6;

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 10px;
                        spacing: 4px;

                        QuestSidebarButton { label: "Knowledge"; glyph: "▱"; active: root.quest-tab == "knowledge"; clicked => { root.quest-tab-selected("knowledge"); } }
                        QuestSidebarButton { label: "Marketplace"; glyph: "⊞"; }
                    }
                }

                Rectangle {
                    height: 52px;
                    background: #F7F7F6;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 10px;
                        spacing: 8px;

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: #DADCE0;
                            Text { text: "R"; color: #3C4043; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 1px;
                            Text { text: "Rownix"; color: #202124; font-size: 12px; font-weight: 600; overflow: elide; }
                            Text { text: "Community"; color: #5F6368; font-size: 11px; overflow: elide; }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: "Update"; color: #FFFFFF; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; width: 54px; height: 18px; }
                        Text { text: "⚙"; color: #5F6368; font-size: 14px; vertical-alignment: center; }
                    }
                }
            }
        }

        Rectangle {
            background: #FFFFFF;
            horizontal-stretch: 1;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 48px;
                    background: #FFFFFF;
                    border-width: 1px;
                    border-color: #EFEFEE;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 12px;
                        spacing: 8px;

                        Text { text: has-selected-quest ? quest-title : "Aster"; color: #202124; font-size: 13px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                        Text { text: "Aster"; color: #9AA0A6; font-size: 12px; vertical-alignment: center; }
                        Text { text: "▣"; color: #9AA0A6; font-size: 12px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        QuestHeaderButton { width: 108px; text: "Open Editor ↗"; enabled: has-selected-quest; clicked => { root.quest-action("open_editor"); } }
                        QuestHeaderButton { width: 30px; text: show-artifact-pane ? "◨" : "◧"; enabled: has-selected-quest; clicked => { root.quest-tab-selected(show-artifact-pane ? "overview" : "spec"); } }
                    }
                }

                if !has-selected-quest: Rectangle {
                    background: #FFFFFF;

                    Rectangle {
                        width: 720px;
                        height: 210px;
                        x: (parent.width - 720px) / 2;
                        y: (parent.height - self.height) / 2 - 30px;
                        background: #FFFFFF;

                        VerticalLayout {
                            spacing: 16px;
                            Text { text: "✦"; color: #85858B; font-size: 32px; horizontal-alignment: center; }
                            Text { text: "What do you want Aster to build?"; color: #202124; font-size: 30px; font-weight: 650; horizontal-alignment: center; }
                            Text { text: "Select an existing Quest or create one from the Tauri Quest workspace."; color: #8A8D91; font-size: 13px; horizontal-alignment: center; }
                        }
                    }
                }

                if has-selected-quest: HorizontalLayout {
                    spacing: 0px;

                    Rectangle {
                        background: #FFFFFF;
                        horizontal-stretch: 1;

                        Rectangle {
                            width: 720px;
                            x: (parent.width - 720px) / 2;
                            y: 18px;
                            height: parent.height - 148px;
                            background: #FFFFFF;

                            ScrollView {
                                VerticalLayout {
                                    spacing: 10px;
                                    padding-bottom: 24px;

                                    Rectangle {
                                        min-height: 36px;
                                        border-radius: 7px;
                                        border-width: 1px;
                                        border-color: #E5E7EB;
                                        background: #F7F7F7;

                                        Text { text: quest-goal; color: #4B5563; font-size: 12px; x: 12px; y: 9px; width: parent.width - 24px; wrap: word-wrap; }
                                    }

                                    for row in root.quest-timeline: Rectangle {
                                        min-height: 38px;
                                        background: #FFFFFF;

                                        HorizontalLayout {
                                            spacing: 10px;

                                            Rectangle {
                                                width: 9px;
                                                height: 9px;
                                                border-radius: 5px;
                                                border-width: 1px;
                                                border-color: #A1A1AA;
                                                background: #FFFFFF;
                                                vertical-stretch: 0;
                                            }

                                            VerticalLayout {
                                                spacing: 3px;
                                                Text { text: row.label; color: #202124; font-size: 12px; font-weight: 500; wrap: word-wrap; }
                                                Text { text: row.detail; color: #8A8D91; font-size: 11px; wrap: word-wrap; }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        min-height: 120px;
                                        border-radius: 7px;
                                        border-width: 1px;
                                        border-color: #E5E5E5;
                                        background: #FFFFFF;

                                        VerticalLayout {
                                            padding: 10px;
                                            spacing: 8px;

                                            HorizontalLayout {
                                                spacing: 8px;
                                                Text { text: "▱"; color: #5F6368; font-size: 13px; vertical-alignment: center; }
                                                Text { text: "Spec"; color: #202124; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                                Text { text: "Spec.md"; color: #8A8D91; font-size: 12px; vertical-alignment: center; }
                                            }
                                            Text { text: quest-next-reason == "" ? quest-next-action : quest-next-reason; color: #3C4043; font-size: 12px; wrap: word-wrap; }
                                            HorizontalLayout {
                                                spacing: 8px;
                                                Rectangle { horizontal-stretch: 1; }
                                                QuestHeaderButton { width: 82px; text: "View detail"; clicked => { root.quest-tab-selected("spec"); } }
                                                QuestHeaderButton { width: 70px; text: "Build"; enabled: quest-status != "archived" && quest-status != "running"; clicked => { root.quest-action("execute"); } }
                                            }
                                        }
                                    }

                                    if quest-status == "running" || quest-status == "validating" || quest-status == "repairing": Rectangle {
                                        min-height: 52px;
                                        background: #FFFFFF;

                                        VerticalLayout {
                                            spacing: 4px;
                                            Text { text: "Generating Quest spec"; color: #202124; font-size: 12px; font-weight: 600; }
                                            Text { text: "waiting for model output and task artifact"; color: #8A8D91; font-size: 11px; }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            width: 720px;
                            height: 108px;
                            x: (parent.width - 720px) / 2;
                            y: parent.height - 126px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #E2E4E7;
                            background: #FFFFFF;

                            VerticalLayout {
                                padding-left: 12px;
                                padding-right: 8px;
                                padding-top: 9px;
                                padding-bottom: 8px;
                                spacing: 10px;

                                Text { text: "Plan, @ for context, / for commands"; color: #B4B8BE; font-size: 13px; }
                                Rectangle { vertical-stretch: 1; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    Text { text: "∞ Agent⌄"; color: #6B7280; font-size: 12px; vertical-alignment: center; }
                                    Text { text: "Auto⌄"; color: #6B7280; font-size: 12px; vertical-alignment: center; }
                                    Text { text: "⌗"; color: #6B7280; font-size: 13px; vertical-alignment: center; }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text { text: "≡  ✧  ♫"; color: #9AA0A6; font-size: 15px; vertical-alignment: center; }
                                    Rectangle { width: 24px; height: 24px; border-radius: 6px; background: #B7B7B7; Text { text: "↑"; color: white; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; } }
                                }
                            }
                        }
                    }

                    if show-artifact-pane: Rectangle {
                        width: 520px;
                        background: #FFFFFF;
                        border-width: 1px;
                        border-color: #E5E5E3;

                        VerticalLayout {
                            spacing: 0px;

                            Rectangle {
                                height: 45px;
                                background: #FFFFFF;
                                border-width: 1px;
                                border-color: #EDEDEB;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 1px;

                                    QuestHeaderButton { width: 42px; text: "↻"; enabled: true; clicked => { root.quest-tab-selected("overview"); } }
                                    QuestHeaderButton { width: 42px; text: "▱"; enabled: true; clicked => { root.quest-tab-selected("intent"); } }
                                    QuestHeaderButton { width: 84px; text: "Spec  ×"; enabled: true; clicked => { root.quest-tab-selected("spec"); } }
                                    QuestHeaderButton { width: 42px; text: "✓"; enabled: true; clicked => { root.quest-tab-selected("review"); } }
                                    QuestHeaderButton { width: 42px; text: "✦"; enabled: true; clicked => { root.quest-tab-selected("knowledge"); } }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                            }

                            Rectangle {
                                height: 48px;
                                background: #FFFFFF;
                                border-width: 1px;
                                border-color: #F0F0EF;

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 2px;

                                    Text { text: quest-tab == "intent" ? "Intent" : (quest-tab == "review" ? "Review" : (quest-tab == "knowledge" ? "Knowledge" : "Spec")); color: #202124; font-size: 13px; font-weight: 600; overflow: elide; }
                                    Text { text: quest-tab == "intent" ? "intent.md" : (quest-tab == "review" ? "review.json" : (quest-tab == "knowledge" ? "project knowledge" : "spec.md")); color: #8A8D91; font-size: 11px; overflow: elide; }
                                }
                            }

                            if quest-tab == "review": ScrollView {
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 10px;
                                    Text { text: "Review"; color: #202124; font-size: 18px; font-weight: 650; }
                                    for metric in root.quest-metrics: QuestMetricCard { metric: metric; }
                                    for row in root.quest-files: Rectangle {
                                        min-height: 38px;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #E5E7EB;
                                        background: #FAFAFA;
                                        Text { text: row.label + "  " + row.detail; color: #3C4043; font-size: 12px; x: 10px; y: 10px; width: parent.width - 20px; overflow: elide; }
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        QuestHeaderButton { width: 76px; text: "Apply"; clicked => { root.quest-action("apply_all"); } }
                                        QuestHeaderButton { width: 82px; text: "Discard"; clicked => { root.quest-action("discard_all"); } }
                                        QuestHeaderButton { width: 76px; text: "Revise"; clicked => { root.quest-action("request_revision"); } }
                                    }
                                }
                            }

                            if quest-tab == "knowledge": ScrollView {
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 8px;
                                    for row in root.quest-knowledge: Rectangle {
                                        min-height: 58px;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #E5E7EB;
                                        background: #FAFAFA;
                                        VerticalLayout {
                                            padding: 10px;
                                            spacing: 4px;
                                            Text { text: row.label; color: #202124; font-size: 12px; font-weight: 600; overflow: elide; }
                                            Text { text: row.detail; color: #6B7280; font-size: 11px; wrap: word-wrap; }
                                        }
                                    }
                                }
                            }

                            if quest-tab != "review" && quest-tab != "knowledge": ScrollView {
                                Rectangle {
                                    background: #FFFFFF;
                                    min-height: 720px;

                                    Text {
                                        x: 26px;
                                        y: 22px;
                                        width: parent.width - 52px;
                                        text: quest-document == "" ? "No artifact content available." : quest-document;
                                        color: #202124;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component IconRailButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> active: false;
    callback clicked();

    width: 40px;
    height: 40px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #1F7A3D : #00000000;
    background: active ? #123421 : #00000000;

    Text {
        text: root.glyph;
        color: active ? #4ADE80 : #85858B;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component InspectorPanel inherits Rectangle {
    in property <string> title;
    in property <string> selected-kind: "Entity";
    in property <[ShellRow]> rows;

    background: #151619;
    border-width: 1px;
    border-color: #2B2C31;

    VerticalLayout {
        spacing: 0px;

        PanelHeader {
            title: root.title;
            kicker: root.selected-kind;
            meta: "◉  ⚙";
        }

        Rectangle {
            height: 34px;
            background: #151619;
            border-width: 1px;
            border-color: #2B2C31;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                Text {
                    text: "⌄ Transform";
                    color: #F4F4F5;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }

        ScrollView {
        VerticalLayout {
            padding: 10px;
            spacing: 0px;

            for row in root.rows: Rectangle {
                height: 32px;
                background: #151619;

                HorizontalLayout {
                    spacing: 8px;

                    Text {
                        text: row.label;
                        color: #85858B;
                        font-size: 11px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Rectangle {
                        width: 116px;
                        height: 22px;
                        border-radius: 5px;
                        border-width: 1px;
                        border-color: #2B2C31;
                        background: #0D0E10;

                    Text {
                        text: row.detail;
                        color: #F4F4F5;
                        font-size: 11px;
                        font-family: "monospace";
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                    }
                }
            }

            Rectangle { height: 1px; background: #2B2C31; }

            Text {
                text: "Components";
                color: #F4F4F5;
                font-size: 12px;
                font-weight: 700;
            }

            Rectangle {
                height: 40px;
                border-radius: 5px;
                border-width: 1px;
                border-color: #2B2C31;
                background: #0D0E10;

                Text {
                    text: root.selected-kind == "Asset" ? "Asset preview/import actions pending." : "Select an object to inspect transform and components.";
                    color: #85858B;
                    font-size: 11px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
        }
    }
}

component ConsolePanel inherits Rectangle {
    in property <[ShellRow]> rows;
    in property <string> active-tab: "problems";
    callback tab-clicked(string);
    callback open-row(int);

    height: 166px;
    background: #151619;
    border-width: 1px;
    border-color: #2B2C31;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 30px;
            background: #151619;
            border-width: 1px;
            border-color: #2B2C31;

            HorizontalLayout {
                padding-left: 12px;
                spacing: 18px;

                Text { text: "Console"; color: active-tab == "console" ? #F4F4F5 : #85858B; font-size: 11px; font-weight: active-tab == "console" ? 700 : 500; vertical-alignment: center; }
                Text { text: "Problems"; color: active-tab == "problems" ? #F4F4F5 : #85858B; font-size: 11px; font-weight: active-tab == "problems" ? 700 : 500; vertical-alignment: center; }
                Text { text: "Tasks"; color: active-tab == "tasks" ? #F4F4F5 : #85858B; font-size: 11px; font-weight: active-tab == "tasks" ? 700 : 500; vertical-alignment: center; }
                Text { text: "Assets"; color: active-tab == "assets" ? #F4F4F5 : #85858B; font-size: 11px; font-weight: active-tab == "assets" ? 700 : 500; vertical-alignment: center; }

                Rectangle { horizontal-stretch: 1; }

                Text { text: "Hide"; color: #85858B; font-size: 11px; vertical-alignment: center; }
            }

            TouchArea {
                clicked => { root.tab-clicked("console"); }
            }
        }

        ScrollView {
            VerticalLayout {
                padding-top: 8px;
                spacing: 0px;

                for row[index] in root.rows: Rectangle {
                    height: 31px;
                    background: row.selected ? #202124 : #151619;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 9px;

                        Text { text: "△"; color: #FBBF24; font-size: 13px; vertical-alignment: center; }
                        Text {
                            text: row.label;
                            color: #C3C3C7;
                            font-size: 11px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        Text {
                            text: row.detail;
                            color: #85858B;
                            font-size: 10px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        ToolButton {
                            width: 48px;
                            text: "Open";
                            clicked => { root.open-row(index); }
                        }
                    }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Aster Editor";
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 1120px;
    min-height: 650px;
    background: #0D0E10;

    in property <string> project-name: "No Project";
    in property <string> project-path: "";
    in property <string> scene-path: "";
    in property <bool> scene-dirty: false;
    in property <int> object-count: 0;
    in property <int> asset-count: 0;
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;
    in property <string> active-screen: "hub";
    in property <string> active-tool: "move";
    in property <string> active-rail: "scene";
    in property <string> console-tab: "problems";
    in property <string> selected-kind: "Entity";
    in property <string> selected-name: "";
    in property <bool> play-mode: false;
    in property <[ShellRow]> hierarchy;
    in property <[ShellRow]> assets;
    in property <[ShellRow]> scripts;
    in property <[ShellRow]> build-rows;
    in property <[ShellRow]> diagnostics;
    in property <[ShellRow]> inspector;
    in property <[ShellRow]> console;
    in property <[QuestSummary]> quests;
    in property <[ShellRow]> quest-timeline;
    in property <[ShellRow]> quest-tasks;
    in property <[ShellRow]> quest-files;
    in property <[ShellRow]> quest-knowledge;
    in property <[QuestMetric]> quest-metrics;
    in property <string> quest-tab: "overview";
    in property <string> quest-title: "Quests";
    in property <string> quest-status: "";
    in property <string> quest-goal: "";
    in property <string> quest-next-action: "";
    in property <string> quest-next-reason: "";
    in property <string> quest-document: "";
    in property <bool> has-selected-quest: false;
    in property <image> scene-image;
    in property <string> scene-status: "Scene View pending";

    callback save-requested();
    callback undo-requested();
    callback redo-requested();
    callback play-toggled();
    callback screen-selected(string);
    callback tool-selected(string);
    callback rail-selected(string);
    callback hierarchy-selected(int);
    callback asset-selected(int);
    callback script-selected(int);
    callback console-tab-selected(string);
    callback console-row-opened(int);
    callback create-object-requested();
    callback delete-selection-requested();
    callback rename-selection-requested();
    callback nudge-selection-requested(string);
    callback add-component-requested(string);
    callback remove-component-requested(string);
    callback create-asset-requested(string);
    callback rename-asset-requested();
    callback delete-asset-requested();
    callback reimport-asset-requested();
    callback reimport-all-assets-requested();
    callback quest-selected(int);
    callback quest-tab-selected(string);
    callback quest-action(string);
    callback scene-pointer-event(string, string, float, float);
    callback scene-scrolled(float);

    VerticalLayout {
        spacing: 0px;

        if active-screen != "quest": Rectangle {
            height: 48px;
            background: #121316E0;
            border-width: 1px;
            border-color: #2B2C31;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 10px;

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 7px;
                    background: #123421;

                    Text { text: "◆"; color: #4ADE80; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }

                VerticalLayout {
                    width: 204px;
                    alignment: center;
                    spacing: 1px;

                    Text { text: "Aster / " + project-name; color: #F4F4F5; font-size: 12px; font-weight: 700; overflow: elide; }
                    Text { text: scene-path; color: #85858B; font-size: 10px; font-family: "monospace"; overflow: elide; }
                }

                Rectangle {
                    height: 32px;
                    horizontal-stretch: 1;
                    border-radius: 7px;
                    border-width: 1px;
                    border-color: #2B2C31;
                    background: #151619;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;

                        Text { text: "⌕"; color: #85858B; font-size: 13px; vertical-alignment: center; }
                        Text { text: "Search actions, assets, entities..."; color: #85858B; font-size: 12px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 30px;
                            height: 20px;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: #2B2C31;
                            Text { text: "⌘K"; color: #85858B; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                ToolButton { width: 32px; height: 32px; text: "▣"; enabled: active-screen == "editor" && scene-dirty; clicked => { root.save-requested(); } }
                ToolButton { width: 32px; height: 32px; text: "↶"; enabled: active-screen == "editor" && can-undo; clicked => { root.undo-requested(); } }
                ToolButton { width: 32px; height: 32px; text: "↷"; enabled: active-screen == "editor" && can-redo; clicked => { root.redo-requested(); } }
                ToolButton { width: 68px; height: 32px; text: play-mode ? "■ Stop" : "▷ Play"; enabled: active-screen == "editor"; active: play-mode; clicked => { root.play-toggled(); } }
                ToolButton { width: 32px; height: 32px; text: "✦"; clicked => { root.screen-selected("quest"); } }
                ToolButton { width: 32px; height: 32px; text: "⚙"; clicked => { root.rail-selected("settings"); } }
            }
        }

        if active-screen == "hub": HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 232px;
                background: #151619;
                border-width: 1px;
                border-color: #2B2C31;

                VerticalLayout {
                    padding: 18px;
                    spacing: 8px;

                    Text { text: "Aster"; color: #F4F4F5; font-size: 20px; font-weight: 800; }
                    Text { text: "Hub"; color: #85858B; font-size: 12px; }
                    Rectangle { height: 16px; }
                    ToolButton { width: 150px; text: "Projects"; active: true; }
                    ToolButton { width: 150px; text: "Installs"; }
                    ToolButton { width: 150px; text: "Settings"; clicked => { root.rail-selected("settings"); } }
                    ToolButton { width: 150px; text: "Quest Workspace"; clicked => { root.screen-selected("quest"); } }
                }
            }

            VerticalLayout {
                padding: 28px;
                spacing: 14px;

                Text { text: "Projects"; color: #F4F4F5; font-size: 24px; font-weight: 800; }
                Text { text: project-path; color: #85858B; font-size: 12px; overflow: elide; }

                Rectangle {
                    height: 96px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #2B2C31;
                    background: #151619;

                    HorizontalLayout {
                        padding: 16px;
                        spacing: 14px;

                        Rectangle { width: 42px; height: 42px; border-radius: 6px; background: #123421; }
                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            Text { text: project-name; color: #F4F4F5; font-size: 15px; font-weight: 700; overflow: elide; }
                            Text { text: object-count + " objects   " + asset-count + " assets"; color: #85858B; font-size: 11px; }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        ToolButton { width: 96px; text: "Open Editor"; clicked => { root.screen-selected("editor"); } }
                    }
                }

                Text { text: "Slint Hub is structural parity only: project picker/create/delete/recent installs still need the shared Hub host."; color: #85858B; font-size: 12px; wrap: word-wrap; }
            }
        }

        if active-screen == "quest": QuestWorkspace {
            quests: quests;
            quest-timeline: quest-timeline;
            quest-tasks: quest-tasks;
            quest-files: quest-files;
            quest-knowledge: quest-knowledge;
            quest-metrics: quest-metrics;
            quest-tab: quest-tab;
            quest-title: quest-title;
            quest-status: quest-status;
            quest-goal: quest-goal;
            quest-next-action: quest-next-action;
            quest-next-reason: quest-next-reason;
            quest-document: quest-document;
            has-selected-quest: has-selected-quest;
            quest-selected(index) => { root.quest-selected(index); }
            quest-tab-selected(tab) => { root.quest-tab-selected(tab); }
            quest-action(action) => { root.quest-action(action); }
        }

        if active-screen == "editor": HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 56px;
                background: #151619;
                border-width: 1px;
                border-color: #2B2C31;

                VerticalLayout {
                    padding-top: 8px;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 4px;

                    IconRailButton { glyph: "⊙"; active: active-rail == "scene"; clicked => { root.rail-selected("scene"); } }
                    IconRailButton { glyph: "◇"; active: active-rail == "assets"; clicked => { root.rail-selected("assets"); } }
                    IconRailButton { glyph: "<>"; active: active-rail == "scripts"; clicked => { root.rail-selected("scripts"); } }
                    IconRailButton { glyph: "⬡"; active: active-rail == "build"; clicked => { root.rail-selected("build"); } }
                    IconRailButton { glyph: "☷"; active: active-rail == "console"; clicked => { root.rail-selected("console"); } }

                    Rectangle { vertical-stretch: 1; }

                    IconRailButton { glyph: "□"; active: active-rail == "files"; clicked => { root.screen-selected("hub"); } }
                }
            }

            Rectangle {
                width: 276px;
                background: #151619;
                border-width: 1px;
                border-color: #2B2C31;

                VerticalLayout {
                    spacing: 0px;

                    Rectangle {
                        height: 42px;
                        background: #151619;
                        border-width: 1px;
                        border-color: #2B2C31;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 8px;
                            spacing: 8px;

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: active-rail == "assets" ? "Assets" : (active-rail == "scripts" ? "Scripts" : (active-rail == "build" ? "Build" : (active-rail == "console" ? "Diagnostics" : "Scene")));
                                    color: #F4F4F5;
                                    font-size: 12px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                Text { text: "Prototype data"; color: #85858B; font-size: 10px; overflow: elide; }
                            }

                            Rectangle { horizontal-stretch: 1; }
                            Text { text: "+  ˅"; color: #85858B; font-size: 11px; vertical-alignment: center; }
                        }
                    }

                    Rectangle {
                        height: 36px;
                        background: #151619;
                        border-width: 1px;
                        border-color: #2B2C31;

                        Rectangle {
                            x: 8px;
                            y: 6px;
                            width: parent.width - 16px;
                            height: 24px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #2B2C31;
                            background: #0D0E10;
                            Text {
                                text: active-rail == "assets" ? "⌕  Filter assets" : (active-rail == "scripts" ? "⌕  Filter scripts" : "⌕  Filter entities");
                                color: #85858B;
                                font-size: 11px;
                                x: 9px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    if active-rail == "scene": ListPanel {
                        height: 76%;
                        title: "Scene";
                        kicker: "Core";
                        meta: object-count;
                        rows: hierarchy;
                        row-clicked(index) => { root.hierarchy-selected(index); }
                    }

                    if active-rail == "assets": ListPanel {
                        height: 76%;
                        title: "Project/Assets";
                        kicker: "Imported";
                        meta: asset-count;
                        rows: assets;
                        row-clicked(index) => { root.asset-selected(index); }
                    }

                    if active-rail == "scripts": ListPanel {
                        height: 76%;
                        title: "Scripts";
                        kicker: "Text assets";
                        meta: asset-count;
                        rows: scripts;
                        row-clicked(index) => { root.script-selected(index); }
                    }

                    if active-rail == "build": ListPanel {
                        height: 76%;
                        title: "Build";
                        kicker: "Package";
                        rows: build-rows;
                    }

                    if active-rail == "console": ListPanel {
                        height: 76%;
                        title: "Diagnostics";
                        kicker: "Console";
                        rows: diagnostics;
                        row-clicked(index) => { root.console-row-opened(index); }
                    }

                    ListPanel {
                        title: "Recent Assets";
                        kicker: "Project";
                        meta: asset-count;
                        rows: assets;
                        row-clicked(index) => { root.asset-selected(index); }
                    }
                }
            }

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 32px;
                    background: #151619;
                    border-width: 1px;
                    border-color: #2B2C31;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        ToolButton { width: 58px; text: "◎ Select"; active: active-tool == "select"; clicked => { root.tool-selected("select"); } }
                        ToolButton { width: 58px; text: "✥ Move"; active: active-tool == "move"; clicked => { root.tool-selected("move"); } }
                        ToolButton { width: 64px; text: "↻ Rotate"; active: active-tool == "rotate"; clicked => { root.tool-selected("rotate"); } }
                        ToolButton { width: 58px; text: "↗ Scale"; active: active-tool == "scale"; clicked => { root.tool-selected("scale"); } }
                        ToolButton { width: 88px; text: "Snap 0.25m"; active: true; }
                        ToolButton { width: 38px; text: "X-"; clicked => { root.nudge-selection-requested("x-"); } }
                        ToolButton { width: 38px; text: "X+"; clicked => { root.nudge-selection-requested("x+"); } }
                        ToolButton { width: 38px; text: "Y-"; clicked => { root.nudge-selection-requested("y-"); } }
                        ToolButton { width: 38px; text: "Y+"; clicked => { root.nudge-selection-requested("y+"); } }
                        ToolButton { width: 38px; text: "Z-"; clicked => { root.nudge-selection-requested("z-"); } }
                        ToolButton { width: 38px; text: "Z+"; clicked => { root.nudge-selection-requested("z+"); } }
                        Text { text: "Lit"; color: #A1A1AA; font-size: 11px; vertical-alignment: center; }
                        ToolButton { width: 58px; text: "3D   2D"; }

                        Rectangle { horizontal-stretch: 1; }

                        Text { text: "• " + scene-status; color: #85858B; font-size: 11px; vertical-alignment: center; overflow: elide; }
                    }
                }

                Rectangle {
                    background: #0D0E10;
                    border-width: 1px;
                    border-color: #222328;

                    Image {
                        source: scene-image;
                        width: parent.width;
                        height: parent.height;
                        image-fit: contain;
                    }

                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 14px;
                        border-width: 2px;
                        border-color: #22C55E;
                        background: #0D0E10;
                        x: parent.width / 2 - 14px;
                        y: parent.height / 2 - 14px;
                    }

                    Rectangle {
                        width: 82px;
                        height: 82px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #2B2C31;
                        background: #151619CC;
                        x: parent.width - 96px;
                        y: 12px;

                        Rectangle { width: 38px; height: 2px; background: #EF4444; x: 22px; y: 41px; }
                        Rectangle { width: 2px; height: 36px; background: #22C55E; x: 41px; y: 16px; }
                        Rectangle { width: 28px; height: 2px; background: #60A5FA; x: 37px; y: 55px; }
                        Rectangle { width: 5px; height: 5px; border-radius: 3px; background: #E5E7EB; x: 39px; y: 39px; }
                        Text { text: "X"; color: #FCA5A5; font-size: 11px; font-weight: 700; x: 62px; y: 28px; }
                        Text { text: "Y"; color: #86EFAC; font-size: 11px; font-weight: 700; x: 37px; y: 8px; }
                        Text { text: "Z"; color: #93C5FD; font-size: 11px; font-weight: 700; x: 58px; y: 54px; }
                    }

                    Rectangle {
                        width: 210px;
                        height: 34px;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: #2B2C31;
                        background: #151619;
                        x: 12px;
                        y: parent.height - 48px;

                        Text {
                            text: selected-name != "" ? "World > " + selected-name : "World > " + project-name + "  •  " + scene-status;
                            color: #C3C3C7;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            overflow: elide;
                        }
                    }

                    Rectangle {
                        width: 330px;
                        height: 34px;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: #2B2C31;
                        background: #151619;
                        x: parent.width - 345px;
                        y: parent.height - 48px;

                        Text {
                            text: selected-name != "" ? "Ask about " + selected-name : "Ask about " + project-name;
                            color: #85858B;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    scene-touch := TouchArea {
                        pointer-event(event) => {
                            root.scene-pointer-event(
                                event.kind == PointerEventKind.down ? "down" : (event.kind == PointerEventKind.up ? "up" : (event.kind == PointerEventKind.cancel ? "cancel" : "move")),
                                event.button == PointerEventButton.right ? "right" : (event.button == PointerEventButton.middle ? "middle" : (event.button == PointerEventButton.left ? "left" : "other")),
                                self.mouse-x / 1px,
                                self.mouse-y / 1px
                            );
                        }
                        scroll-event(event) => {
                            root.scene-scrolled(event.delta-y / 1px);
                            accept
                        }
                    }
                }

                ConsolePanel {
                    rows: console;
                    active-tab: console-tab;
                    tab-clicked(tab) => { root.console-tab-selected(tab); }
                    open-row(index) => { root.console-row-opened(index); }
                }
            }

            InspectorPanel {
                width: 280px;
                title: selected-name != "" ? selected-name : project-name;
                selected-kind: selected-kind;
                rows: inspector;
            }
        }

        Rectangle {
            height: 23px;
            background: #121316E0;
            border-width: 1px;
            border-color: #2B2C31;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                Text { text: scene-dirty ? "• unsaved" : "✓ saved"; color: scene-dirty ? #FBBF24 : #34D399; font-size: 11px; vertical-alignment: center; }
                Text { text: "runtime-min"; color: #85858B; font-size: 11px; vertical-alignment: center; }
                Text { text: selected-name != "" ? selected-name : project-name; color: #A1A1AA; font-size: 11px; vertical-alignment: center; }

                Rectangle { horizontal-stretch: 1; }

                Text { text: object-count + " objects   " + asset-count + " assets   " + (play-mode ? "Playing" : "60 FPS"); color: #85858B; font-size: 11px; vertical-alignment: center; }
                Text { text: scene-path; color: #686970; font-size: 11px; vertical-alignment: center; overflow: elide; }
            }
        }
    }
}

export component GameViewWindow inherits Window {
    title: "Game View";
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 640px;
    min-height: 360px;
    background: #0D0E10;

    in property <string> project-name: "Game View";
    in property <string> status: "";
    in property <image> game-image;

    Rectangle {
        background: #0D0E10;

        Image {
            source: game-image;
            width: parent.width;
            height: parent.height;
            image-fit: contain;
        }

        Rectangle {
            height: 36px;
            background: #151619D9;
            border-width: 1px;
            border-color: #2B2C31;
            y: 0px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;

                Text { text: "▷ " + project-name; color: #F4F4F5; font-size: 13px; font-weight: 700; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                Text { text: status; color: #85858B; font-size: 11px; vertical-alignment: center; overflow: elide; }
            }
        }
    }
}
