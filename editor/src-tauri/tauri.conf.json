{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Aster Editor",
  "version": "0.1.0",
  "identifier": "com.aster.editor",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "Aster Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#181818",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "nsis", "dmg"],
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/applications/com.aster.editor.desktop": "linux/com.aster.editor.desktop",
          "/usr/share/icons/hicolor/512x512/apps/com.aster.editor.png": "icons/icon.png"
        }
      },
      "deb": {
        "files": {
          "/usr/share/applications/com.aster.editor.desktop": "linux/com.aster.editor.desktop",
          "/usr/share/icons/hicolor/512x512/apps/com.aster.editor.png": "icons/icon.png"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/applications/com.aster.editor.desktop": "linux/com.aster.editor.desktop",
          "/usr/share/icons/hicolor/512x512/apps/com.aster.editor.png": "icons/icon.png"
        }
      }
    }
  }
}
